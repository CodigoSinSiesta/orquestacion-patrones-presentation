---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Patrones de Orquestación — Codigo Sin Siesta' } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta
      name="description"
      content="10 patrones de orquestación de agentes IA. 3 módulos independientes: taxonomía evolutiva, por problema que resuelven, convergencias industria (Anthropic, OpenAI, Factory, Academia)."
    />
    <link rel="icon" type="image/svg+xml" href="favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body>
    <slot />
  </body>
</html>
